{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metaclaw.local/schemas/marketplace-index.schema.json",
  "title": "MetaClaw Marketplace Index",
  "type": "object",
  "required": ["version", "last_updated", "items"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Marketplace index format version."
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp for the latest index update."
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "name", "version", "description", "manifest_url"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["skill", "tool", "plugin"]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "author": {
            "type": "string"
          },
          "homepage": {
            "type": "string",
            "format": "uri"
          },
          "manifest_url": {
            "type": "string",
            "format": "uri"
          },
          "checksum_sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
